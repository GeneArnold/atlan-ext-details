# Atlan Instance Configuration
# Your Atlan instance URL (without trailing slash)
ATLAN_INSTANCE_URL=https://your-instance.atlan.com

# OAuth Client Configuration
# Client ID from your OAuth application registration
OAUTH_CLIENT_ID=your-client-id-here

# Client Secret (may not be needed for public PKCE clients)
# Leave empty if using PKCE without client secret
OAUTH_CLIENT_SECRET=

# OAuth Endpoints
# These are typically in the format: https://your-instance.atlan.com/auth/realms/{realm}/protocol/openid-connect/{endpoint}
# For Keycloak, the realm is usually 'default' or your org name

# Authorization endpoint - where users are redirected to login
OAUTH_AUTH_ENDPOINT=https://your-instance.atlan.com/auth/realms/default/protocol/openid-connect/auth

# Token endpoint - where we exchange the auth code for tokens
OAUTH_TOKEN_ENDPOINT=https://your-instance.atlan.com/auth/realms/default/protocol/openid-connect/token

# OAuth Redirect URI - must match exactly what's registered in your OAuth app
# For local development, this will be:
OAUTH_REDIRECT_URI=http://localhost:3000/callback

# OAuth Scope - permissions requested
# Common scopes: openid (required), profile, email, offline_access (for refresh tokens)
OAUTH_SCOPE=openid profile email offline_access

# Session Secret - used to sign session cookies
# Generate a random string for production
SESSION_SECRET=development-secret-change-in-production

# Port Configuration (optional, defaults to 3000)
PORT=3000